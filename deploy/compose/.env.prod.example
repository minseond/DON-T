# Image tags are immutable (recommend: git SHA)
BACKEND_IMAGE=registry.example.com/awesome/awesome-backend:20260317-abcdef12
FRONTEND_IMAGE=registry.example.com/awesome/awesome-frontend:20260317-abcdef12

# Spring backend runtime env
DB_URL=jdbc:postgresql://db.internal:5432/awesome
DB_USERNAME=awesome_user
DB_PASSWORD=change_me
API_PATH=/api/v1

# Redis connection from backend
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
AUTH_JWT_SECRET=replace_with_secure_random
AUTH_JWT_ISSUER=awesome-spring-project
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=1209600

# Metadata
RELEASE_ID=manual
GIT_SHA=manual
