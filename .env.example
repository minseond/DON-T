DB_URL=jdbc:postgresql://localhost:5432/awesome
DB_USERNAME=awesome_user
DB_PASSWORD=change_me
API_PATH=/api/v1
SECURITY_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173,https://*.ssafy.io

APP_NAME=awesome-spring-project
BACKEND_DIR=backend
FRONTEND_DIR=frontend
DEV_BRANCH=develop
PROD_BRANCH=main

DOCKER_REGISTRY=registry.example.com
DOCKER_NAMESPACE=awesome
BACKEND_IMAGE_NAME=awesome-backend
FRONTEND_IMAGE_NAME=awesome-frontend

DEV_DEPLOY_HOST=dev.example.com
PROD_DEPLOY_HOST=prod.example.com
DEPLOY_SSH_USER=deploy

GIT_CREDENTIALS_ID=git-credentials-id
REGISTRY_CREDENTIALS_ID=registry-credentials-id
DEPLOY_SSH_CREDENTIALS_ID=deploy-ssh-key-id
JAVA_TRUSTSTORE_FILE_CRED_ID=java-truststore-file-id
JAVA_TRUSTSTORE_PASSWORD_CRED_ID=java-truststore-password-id
NODE_CA_CERT_FILE_CRED_ID=node-ca-cert-file-id
DB_URL_CRED_ID=db-url-id
DB_USERNAME_CRED_ID=db-username-id
DB_PASSWORD_CRED_ID=db-password-id
DB_HIKARI_MAXIMUM_POOL_SIZE=5
DB_HIKARI_MINIMUM_IDLE=1
DB_HIKARI_CONNECTION_TIMEOUT=3000
DB_HIKARI_IDLE_TIMEOUT=300000
DB_HIKARI_MAX_LIFETIME=1800000

AUTH_JWT_SECRET=auth-jwt-secret
AUTH_JWT_ISSUER=awesome-spring-project
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=1209600

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

AUTH_REFRESH_COOKIE_NAME=__Host-refresh
AUTH_REFRESH_COOKIE_PATH=/
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_SAME_SITE=Lax

AWS_S3_BUCKET=s3-bucket
AWS_S3_REGION=ap-northeast-2
AWS_S3_PRESIGN_DEFAULT_EXPIRE_SECONDS=300
AWS_S3_PRESIGN_MAX_EXPIRE_SECONDS=900
AWS_S3_UPLOAD_MAX_SINGLE_BYTES=10485760
AWS_S3_UPLOAD_MAX_TOTAL_BYTES=52428800
AWS_S3_UPLOAD_MAX_FILE_COUNT=10
AWS_S3_PUBLIC_CACHE_CONTROL=public, max-age=31536000, immutable
AWS_S3_PRIVATE_CACHE_CONTROL=private, no-store

AWS_ACCESS_KEY_ID=aws-access-key
AWS_SECRET_ACCESS_KEY=aws-secret-key

VITE_API_BASE_URL=/api/v1

SSL_ENABLED=false
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain/privkey.pem

SECURITY_CORS_ALLOWED_ORIGIN_PATTERNS=https://asdfasdf.asdfasdf.afsdf,https://*.asdfasdf.asdfsadf
