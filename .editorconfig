root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java,gradle,xml,yml,yaml,properties}]
indent_style = space
indent_size = 4

[*.{js,jsx,ts,tsx,json,html,css,scss,md}]
indent_style = space
indent_size = 2

[*.sh]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4
